FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY requirements/scene.txt /tmp/requirements-scene.txt
RUN pip install --no-cache-dir -r /tmp/requirements-scene.txt

COPY app /workspace/app

CMD ["python3", "-m", "uvicorn", "app.scene.api_main:app", "--host", "0.0.0.0", "--port", "7860"]
