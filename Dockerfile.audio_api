FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /workspace

COPY requirements/audio_api.txt /tmp/requirements-audio-api.txt
RUN pip install --no-cache-dir -r /tmp/requirements-audio-api.txt

COPY app /workspace/app

CMD ["python3", "-m", "uvicorn", "app.audio_api.main:app", "--host", "0.0.0.0", "--port", "7860"]
